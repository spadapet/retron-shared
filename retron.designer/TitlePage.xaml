<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
    xmlns:ff="clr-namespace:ff"
    xmlns:local="clr-namespace:ReTron"
    x:Class="ReTron.TitlePage"
    x:Name="root"
    mc:Ignorable="d"
    d:DesignWidth="480"
    d:DesignHeight="270"
    d:Background="Black"
    d:FontFamily="{StaticResource Font.Family.Default}"
    d:FontSize="{StaticResource Font.Size.Normal}"
    d:DataContext="{d:DesignInstance local:TitlePageViewModel, IsDesignTimeCreatable=True}"
    DataContext="{Binding ViewModel, RelativeSource={RelativeSource Mode=Self}}"
    Foreground="{StaticResource Brush.Foreground.Normal}"
    UseLayoutRounding="True">

    <UserControl.InputBindings>
        <KeyBinding Key="Left" Command="{Binding FocusLeftRightCommand, ElementName=root}" CommandParameter="{StaticResource FalseBoolean}" />
        <KeyBinding Key="Right" Command="{Binding FocusLeftRightCommand, ElementName=root}" CommandParameter="{StaticResource TrueBoolean}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <ControlTemplate x:Key="OptionButtonTemplate" TargetType="{x:Type Button}">
            <Grid x:Name="grid" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.231}" />
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Checked}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="OptionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.230}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource OptionButtonTemplate}"/>
            <Setter Property="noesis:StyleInteraction.Triggers">
                <Setter.Value>
                    <noesis:StyleTriggerCollection>
                        <i:EventTrigger EventName="MouseEnter">
                            <noesis:SetFocusAction />
                        </i:EventTrigger>
                    </noesis:StyleTriggerCollection>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,135,0,0" Width="150">
        <Button Content="Start Game" Style="{StaticResource OptionButtonStyle}" Command="{Binding StartGameCommand}" >
            <i:Interaction.Triggers>
                <i:EventTrigger>
                    <noesis:SetFocusAction/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>

        <Button Content="Options" Style="{StaticResource OptionButtonStyle}" Command="{Binding OptionsCommand}" />
        <Button Content="High Scores" Style="{StaticResource OptionButtonStyle}" Command="{Binding HighScoresCommand}" />
        <Button Content="About" Style="{StaticResource OptionButtonStyle}" Command="{Binding AboutCommand}" />

        <Button Style="{StaticResource OptionButtonStyle}" Command="{Binding PlayersCommand}">
            <TextBlock Text="{Binding PlayersText, StringFormat=Players: {0}}" />
        </Button>

        <Button Style="{StaticResource OptionButtonStyle}" Command="{Binding DifficultyCommand}">
            <TextBlock Text="{Binding DifficultyText, StringFormat=Difficulty: {0}}" />
        </Button>

        <Button Style="{StaticResource OptionButtonStyle}" Command="{Binding SoundCommand}">
            <TextBlock Text="{Binding SoundText, StringFormat=Sound: {0}}" />
        </Button>

        <Button Style="{StaticResource OptionButtonStyle}" Command="{Binding FullScreenCommand}">
            <TextBlock Text="{Binding FullScreenText, StringFormat=Full Screen: {0}}" />
        </Button>

    </StackPanel>

</UserControl>
