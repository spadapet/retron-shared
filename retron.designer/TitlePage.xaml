<UserControl
    x:Class="ReTron.TitlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ReTron"
    xmlns:sys="clr-namespace:System;assembly=System"
    mc:Ignorable="d"
    d:DesignWidth="480"
    d:DesignHeight="270"
    d:Background="Black"
    d:FontFamily="{StaticResource Font.Family.Default}"
    d:FontSize="{StaticResource Font.Size.Normal}"
    d:DataContext="{d:DesignInstance local:TitlePageViewModel, IsDesignTimeCreatable=True}"
    DataContext="{Binding ViewModel, RelativeSource={RelativeSource Mode=Self}}"
    UseLayoutRounding="True"
    Foreground="{StaticResource Brush.Foreground.Normal}"
    Loaded="OnLoaded">

    <UserControl.Resources>
        <ControlTemplate x:Key="OptionButtonTemplate" TargetType="Button">
            <Grid Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.231}" />
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Checked}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="OptionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.230}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource OptionButtonTemplate}"/>
        </Style>

        <DataTemplate x:Key="PlayersTemplate" DataType="sys:String">
            <TextBlock><Run Text="Players: " /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="DifficultyTemplate" DataType="sys:String">
            <TextBlock><Run Text="Difficulty: " /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="SoundTemplate" DataType="sys:String">
            <TextBlock><Run Text="Sound: " /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="FullScreenTemplate" DataType="sys:String">
            <TextBlock><Run Text="Full Screen: " /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
        </DataTemplate>

    </UserControl.Resources>

    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,135,0,0" Width="150">
        <Button
            Name="startGameButton"
            Style="{StaticResource OptionButtonStyle}"
            Content="Start Game"
            MouseEnter="OnOptionMouseEnter"
            Command="{Binding StartGameCommand}" />

        <Button
            Style="{StaticResource OptionButtonStyle}"
            Content="Options"
            MouseEnter="OnOptionMouseEnter"
            Command="{Binding OptionsCommand}" />

        <Button
            Style="{StaticResource OptionButtonStyle}"
            Content="High Scores"
            MouseEnter="OnOptionMouseEnter"
            Command="{Binding HighScoresCommand}" />

        <Button
            Style="{StaticResource OptionButtonStyle}"
            Content="About"
            MouseEnter="OnOptionMouseEnter"
            Command="{Binding AboutCommand}" />

        <Button
            Style="{StaticResource OptionButtonStyle}"
            Content="{Binding PlayersText}"
            ContentTemplate="{StaticResource PlayersTemplate}"
            KeyDown="OnPlayersKeyDown"
            MouseEnter="OnOptionMouseEnter"
            Command="{Binding PlayersCommand}" />

        <Button
            Style="{StaticResource OptionButtonStyle}"
            Content="{Binding DifficultyText}"
            ContentTemplate="{StaticResource DifficultyTemplate}"
            KeyDown="OnDifficultyKeyDown"
            MouseEnter="OnOptionMouseEnter"
            Command="{Binding DifficultyCommand}" />

    </StackPanel>

</UserControl>
