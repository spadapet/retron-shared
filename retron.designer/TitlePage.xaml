<UserControl
    x:Class="ReTron.TitlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ReTron"
    xmlns:sys="clr-namespace:System;assembly=System"
    mc:Ignorable="d"
    d:DesignWidth="480"
    d:DesignHeight="270"
    d:Background="Black"
    d:FontFamily="{StaticResource Font.Family.Default}"
    d:FontSize="{StaticResource Font.Size.Normal}"
    d:DataContext="{d:DesignInstance local:TitlePageViewModel, IsDesignTimeCreatable=True}"
    DataContext="{Binding ViewModel, RelativeSource={RelativeSource Mode=Self}}"
    Foreground="{StaticResource Brush.Foreground.Normal}"
    Loaded="OnLoaded">

    <UserControl.Resources>
        <DataTemplate x:Key="DifficultyTemplate" DataType="sys:String">
            <TextBlock>
                <Run Text="Difficulty: " /><Run Text="{Binding Mode=OneWay}" />
            </TextBlock>
        </DataTemplate>
        <Style x:Key="OptionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource Brush.230}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Command" Value="{Binding DifficultyCommand}" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.231}" />
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Checked}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,135,0,0" Width="150">
        <Button
            Name="difficultyButton"
            Style="{StaticResource OptionButtonStyle}"
            Content="{Binding DifficultyText}"
            ContentTemplate="{StaticResource DifficultyTemplate}"
            KeyDown="OnDifficultyKeyDown"
            MouseEnter="OnDifficultyMouseEnter" />

        <Button
            Name="difficultyButton1"
            Style="{StaticResource OptionButtonStyle}"
            Content="{Binding DifficultyText}"
            ContentTemplate="{StaticResource DifficultyTemplate}"
            KeyDown="OnDifficultyKeyDown"
            MouseEnter="OnDifficultyMouseEnter" />

        <Button
            Name="difficultyButton2"
            Style="{StaticResource OptionButtonStyle}"
            Content="{Binding DifficultyText}"
            ContentTemplate="{StaticResource DifficultyTemplate}"
            KeyDown="OnDifficultyKeyDown"
            MouseEnter="OnDifficultyMouseEnter" />
    </StackPanel>

